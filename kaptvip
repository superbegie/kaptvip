function damageBoosterLesley()
    gg.clearResults()
    gg.setRanges(gg.REGION_ANONYMOUS)

    local stats = {HP = 2280, ATK = 145, DEF = 14, MDEF = 15, SPD = 240}

    gg.alert("👉 Lesley Inject Ready", "Proceed")

    local custom = gg.choice({"Use Default Values", "Custom Values"}, 1, "Choose Inject Mode")
    if not custom then return end

    local new_value_HP = stats.HP
    local new_value_ATK = 12345
    local new_value_SPD = stats.SPD
    local new_value_DEF = stats.DEF

    if custom == 2 then
        local input = gg.prompt(
            {"Enter HP", "Enter ATK", "Enter SPD", "Enter Defence"},
            {stats.HP, stats.ATK, stats.SPD, stats.DEF},
            {"number", "number", "number", "number"}
        )
        if not input then return end

        new_value_HP = tonumber(input[1]) or stats.HP
        new_value_ATK = tonumber(input[2]) or stats.ATK
        new_value_SPD = tonumber(input[3]) or stats.SPD
        new_value_DEF = tonumber(input[4]) or stats.DEF
    end

    -- Lesley Inject Process
    gg.searchNumber(string.format("%d;%d;%d;%d;%d", stats.HP, stats.ATK, stats.DEF, stats.MDEF, stats.SPD), gg.TYPE_DWORD)
    gg.refineNumber(string.format("%d;%d", stats.DEF, stats.MDEF), gg.TYPE_DWORD)
    gg.getResults(100)
    gg.editAll(new_value_DEF, gg.TYPE_DWORD)
    gg.clearResults()

    gg.searchNumber(string.format("%d;%d;%d;%d;%d", stats.HP, stats.ATK, new_value_DEF, new_value_DEF, stats.SPD), gg.TYPE_DWORD)
    gg.refineNumber(stats.HP, gg.TYPE_DWORD)
    gg.getResults(100)
    gg.editAll(new_value_HP, gg.TYPE_DWORD)
    gg.clearResults()

    gg.searchNumber(string.format("%d;%d;%d;%d;%d", new_value_HP, stats.ATK, new_value_DEF, new_value_DEF, stats.SPD), gg.TYPE_DWORD)
    gg.refineNumber(stats.ATK, gg.TYPE_DWORD)
    gg.getResults(100)
    gg.editAll(new_value_ATK, gg.TYPE_DWORD)
    gg.clearResults()

    gg.searchNumber(string.format("%d;%d;%d;%d;%d", new_value_HP, new_value_ATK, new_value_DEF, new_value_DEF, stats.SPD), gg.TYPE_DWORD)
    gg.refineNumber(stats.SPD, gg.TYPE_DWORD)
    gg.getResults(100)
    gg.editAll(new_value_SPD, gg.TYPE_DWORD)
    gg.clearResults()

    gg.toast("✅ Lesley Inject Successful!")
end

