function skipperClassic()
    gg.clearResults()
    gg.setRanges(gg.REGION_ANONYMOUS)

    local waktuList = {"⏳ 04:00", "⏳ 08:00", "⏳ 10:00", "⏳ 12:00"}
    local waktuMap = {
        ["⏳ 04:00"] = 240000,
        ["⏳ 08:00"] = 480000,
        ["⏳ 10:00"] = 600000,
        ["⏳ 12:00"] = 720000
    }

    local pilihan = gg.choice(waktuList, nil, "🎮 Skip / Reset Match Time")
    if not pilihan then return end

    gg.searchNumber("30000;45000;1", gg.TYPE_DWORD)
    gg.refineNumber("30000", gg.TYPE_DWORD)
    local hasil = gg.getResults(10)

    if #hasil == 0 then
        gg.toast("No results found. Try again.")
        return
    end

    local save = {}
    for i, v in ipairs(hasil) do
        table.insert(save, { address = v.address - 0x8, flags = gg.TYPE_DWORD })
    end

    local sebelum = gg.getValues(save)
    gg.sleep(500)
    local sesudah = gg.getValues(save)

    local target = nil
    for i = 1, #sebelum do
        if sebelum[i].value ~= sesudah[i].value then
            target = save[i]
            break
        end
    end

    if not target then
        gg.toast("Failed to detect time address.")
        return
    end

    target.value = waktuMap[waktuList[pilihan]]
    target.name = "Match Time"

    gg.setValues({target})
    gg.addListItems({target})
    gg.toast("✅ Match time set to " .. waktuList[pilihan])

    gg.clearList()
    gg.clearResults()
end

